# Server
PORT=5000
NODE_ENV=development

# Postgres connection
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=bus_student_db

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=8h

# Seed admin (used only by `npm run seed`)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@12345
